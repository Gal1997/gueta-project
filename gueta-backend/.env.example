# Server
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Database (matches docker-compose.yml)
DATABASE_URL=postgresql://gueta:gueta@localhost:5432/gueta?schema=public

# Secrets (use long random strings in production)
JWT_SECRET=change-me-to-a-long-random-string
COOKIE_SECRET=change-me-to-another-long-random-string

# Google OAuth (create a "Web application" OAuth client in Google Cloud Console)
# Leave empty to disable Google login until you set it up.
GOOGLE_CLIENT_ID=
