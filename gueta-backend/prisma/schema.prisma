generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  password
  google
}

enum IncomeType {
  salary
  investments
  other
}

enum ExpenseCategory {
  debt
  fixed
  food
  shopping
  fuel
  other
}

enum ExpenseRecurrence {
  recurring
  once
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String?
  provider     AuthProvider @default(password)
  googleId     String?      @unique
  onboarded    Boolean      @default(false)
  accumulatedSavings    Int      @default(0)
  savingsRolledUpThrough String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  incomes  Income[]
  expenses Expense[]
  goals    Goal[]
  availableCash     AvailableCash[]
  capitalInvestments CapitalInvestment[]
  futureMoney       FutureMoney[]
  capitalSnapshots  CapitalMonthlySnapshot[]
}

model Income {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        IncomeType
  source      String
  description String
  amount      Int
  currency    Currency          @default(ILS)
  createdAt   DateTime   @default(now())

  @@index([userId])
}

model Expense {
  id                String          @id @default(cuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category          ExpenseCategory
  name              String
  amount            Int
  currency          Currency          @default(ILS)
  description       String
  recurrence        ExpenseRecurrence @default(recurring)
  remainingPayments Int
  totalPayments     Int?
  monthlyCharge     Int?
  billingDate       DateTime
  createdAt         DateTime        @default(now())

  @@index([userId])
}

model Goal {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  description  String
  targetAmount Int
  currency     Currency          @default(ILS)
  targetDate   DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
}

enum AvailableCashType {
  cash
  checking
  bit
  paybox
  daily_deposit
  other
}

enum CapitalInvestmentType {
  deposit
  investments
  pension_fund
  real_estate
  other
}

enum Currency {
  ILS
  USD
  EUR
}

model AvailableCash {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        AvailableCashType
  amount      Int
  currency    Currency          @default(ILS)
  description String?
  updatedAt   DateTime          @updatedAt
  createdAt   DateTime          @default(now())

  @@index([userId])
}

model CapitalInvestment {
  id               String                @id @default(cuid())
  userId           String
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  type             CapitalInvestmentType
  amount           Int
  principalAmount  Int
  currency         Currency              @default(ILS)
  url              String?
  description      String?
  updatedAt        DateTime              @updatedAt
  createdAt        DateTime              @default(now())

  @@index([userId])
}

model FutureMoney {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  description         String
  amount              Int
  currency            Currency  @default(ILS)
  expectedPaymentDate DateTime?
  updatedAt           DateTime  @updatedAt
  createdAt           DateTime  @default(now())

  @@index([userId])
}

model CapitalMonthlySnapshot {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthKey     String
  totalCapital Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, monthKey])
  @@index([userId])
}
